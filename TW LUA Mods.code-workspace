{
	"folders": [
		{
			"name": "Total War Lua Mods",
			"path": "."
		}
	],
	"settings": {
		"[lua]": {
			"editor.quickSuggestions": {
				"other": true,
				"comments": true,
				"strings": true,
			},
			"editor.quickSuggestionsDelay": 1,
			"editor.snippetSuggestions": "inline",
			"editor.tabCompletion": "on",
			"files.eol": "\n",
			"files.encoding": "utf8", //Changed from true
			"editor.suggest.snippetsPreventQuickSuggestions": false,
			"editor.tabSize": 5,
			"editor.detectIndentation": false,
			"editor.defaultFormatter": "Koihik.vscode-lua-format"
		},
		"Lua.workspace.library": [
			"../Total War LUA Autogen/output/wh3/",
			"../Total War LUA Autogen/output/wh3/battle/",
			"../Total War LUA Autogen/output/wh3/campaign/",
			"../Total War LUA Autogen/output/wh3/frontend/",
			"../Total War LUA Autogen/output/wh3/global/",
			"${3rd}/lfs/library"
		],
		"Lua.workspace.ignoreDir": [
			".vscode",
			"docgen.lua",
			"docgen",
			"autotest",
			"unit_balance_testing",
			"benchmarks",
			"test_battles",
			"unit_balance_testing",
			"bespoke_cincam_testing",
			"export_ui_metadata.lua",
			"patch_note_helper",
			"**/*Older Projects*/**",
			"**/*[Bb]ackup*/**",
			"**/*[Ss]crap*/**",
			"**/*[Ee]xample*/**",
			"**/*Vanilla*/**"
		],
		"files.exclude": {
			"**/.gitignore": false,
			"**/.git/**": true,
			"**/desktop.ini": true,
			"**/README.md": false,
			"**/*sync.ffs_*": true,
			"**/*-Jessica-PC*/**": true
		},
		"workbench.colorCustomizations": {
			"[Just Black + Comments]": {},
			"activityBar.background": "#9B4207",
			"titleBar.activeBackground": "#D95D0A",
			"titleBar.activeForeground": "#FFF8F4",
			"titleBar.inactiveBackground": "#9B4207",
			"titleBar.inactiveForeground": "#FFF8F4",
			"statusBar.background": "#9B4207",
			"statusBar.foreground": "#FFF8F4",
			"statusBar.debuggingBackground": "#9B4207",
			"statusBar.debuggingForeground": "#FFF8F4",
			"statusBar.noFolderBackground": "#9B4207",
			"statusBar.noFolderForeground": "#FFF8F4"
		},
		"metalua-formatter.indentSize": 5
	}
}